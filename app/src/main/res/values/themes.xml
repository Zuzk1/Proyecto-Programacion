<resources>

    <style name="Base.Theme.Pomodoro" parent="Theme.Material3.DayNight.NoActionBar">

    </style>

    <style name="Theme.Pomodoro" parent="Base.Theme.Pomodoro" />

    <!-- TemaSplash Screen -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Color de fondo de la animacion -->
        <item name="windowSplashScreenBackground">#1A1A24</item>
        <!-- Define el recurso del icono a mostrar -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <!-- Define el tema original al que cambiara despues de la animacion -->
        <item name="postSplashScreenTheme">@style/Theme.Pomodoro</item>
    </style>

    <style name="EstiloTextoNavegador">
        <item name="android:textSize">14sp</item>
    </style>
</resources>