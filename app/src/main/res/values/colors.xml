    <color name="color_gris_navegacion_apagada">#5A5A5A</color>
    <!-- Gris del indicador de ciclo ya completado -->
    <color name="color_gris_indicador_apagado">#555555</color>
    <!-- Gris usado al restaurar los indicadores de ciclo a su estado inicial -->
    <color name="color_gris_indicador_restaurado">#333333</color>
    <!-- Gris del indicador de ciclo inactivo (forma del círculo) -->
    <color name="color_gris_ciclo_inactivo">#444444</color>

    <!-- Verde de éxito (racha activa, sesión de enfoque completada) -->
    <color name="color_verde_exito">#4CAF50</color>

    <!-- Rojo de peligro (botón renunciar, alertas) -->
    <color name="color_rojo_peligro">#E53935</color>
