    <color name="color_rojo_glow">#4DE53935</color>

    <!-- Negro semitransparente usado como overlay del modal de redacción -->
    <color name="color_negro_overlay_50">#80000000</color>
    <!-- Blanco semitransparente para puntos inactivos del onboarding -->
    <color name="color_blanco_overlay_20">#33FFFFFF</color>
    <!-- Blanco semitransparente para subtítulos del onboarding -->
    <color name="color_blanco_overlay_60">#99FFFFFF</color>
