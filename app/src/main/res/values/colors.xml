    <color name="color_gris_texto_secundario">#A0A0A0</color>
    <!-- Gris para textos terciarios (ej. días de la semana en la gráfica) -->
    <color name="color_gris_texto_terciario">#888888</color>
    <!-- Gris claro para etiquetas (ej. "Tarea activa:") -->
    <color name="color_gris_texto_claro">#AAAAAA</color>
