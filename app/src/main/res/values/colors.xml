<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Blanco puro -->
    <color name="white">#FFFFFFFF</color>
    <!-- Negro puro -->
    <color name="black">#FF000000</color>
    <!-- Totalmente transparente -->
    <color name="color_transparente">#00000000</color>

    <!-- Azul principal de la app (botones, acentos, colorPrimary/colorSecondary) -->
    <color name="color_azul_principal">#2196F3</color>
    <!-- Azul claro usado en textos destacados de la pantalla de bienvenida -->
    <color name="color_azul_claro">#64B5F6</color>
    <!-- Azul oscuro del contenedor secundario (indicador activo de la navegación inferior) -->
    <color name="color_azul_contenedor_secundario">#1A3A5C</color>
    <!-- Azul principal con 10% de opacidad, usado en chips/fondos resaltados -->
    <color name="color_azul_overlay_10">#1A2196F3</color>
    <!-- Azul principal con 20% de opacidad, usado en bordes de fondos resaltados -->
    <color name="color_azul_overlay_20">#332196F3</color>

    <!-- Fondo oscuro principal de las pantallas de la app -->
    <color name="color_fondo_principal">#1F1F24</color>
    <!-- Fondo de la barra de navegación inferior -->
    <color name="color_fondo_barra_navegacion">#1E1E24</color>
    <!-- Fondo del splash screen -->
    <color name="color_fondo_splash">#1A1A24</color>
    <!-- Fondo de tarjetas oscuras (cards de estadísticas, tareas, etc.) -->
    <color name="color_fondo_tarjeta">#26262D</color>
    <!-- Fondo de la tarjeta de tareas en onboarding -->
    <color name="color_fondo_tarjeta_onboarding">#26262C</color>
    <!-- Fondo del contenedor de la tarea activa -->
    <color name="color_fondo_tarjeta_activa">#25252D</color>
