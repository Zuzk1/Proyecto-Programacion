
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F1F24"
    tools:context=".CronometroActivity">

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="SESIÓN DE ENFOQUE"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enfocado en: Estudiar para el Examen"
        android:textColor="#A0A0A0"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitulo" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/pbCronometro"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="32dp"
        android:max="100"
        android:progress="75"
        app:indicatorColor="#FFFFFF"
        app:indicatorSize="240dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitulo"
        app:trackColor="#2E2E35"
        app:trackThickness="14dp"
        app:trackCornerRadius="7dp" />

    <TextView
        android:id="@+id/tvTiempo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25:00"
        android:textColor="#FFFFFF"
        android:textSize="56sp"
        android:textStyle="bold"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toBottomOf="@+id/pbCronometro"
        app:layout_constraintEnd_toEndOf="@+id/pbCronometro"
        app:layout_constraintStart_toStartOf="@+id/pbCronometro"
        app:layout_constraintTop_toTopOf="@+id/pbCronometro" />

    <LinearLayout
        android:id="@+id/llIndicadores"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pbCronometro">

        <TextView
            android:id="@+id/tvCiclo1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/ciclo_activo"
            android:gravity="center"
            android:text="1"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCiclo2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/ciclo_inactivo"
            android:gravity="center"
            android:text="2"
            android:textColor="#888888"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCiclo3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/ciclo_inactivo"
            android:gravity="center"
            android:text="3"
            android:textColor="#888888"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCiclo4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ciclo_inactivo"
            android:gravity="center"
            android:text="4"
            android:textColor="#888888"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llControles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llIndicadores">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnRenunciar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Renunciar"
            app:backgroundTint="#E53935"
            app:tint="#FFFFFF"
            app:elevation="4dp"
            app:fabSize="normal" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnPausar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_media_pause"
            android:contentDescription="Pausar"
            app:backgroundTint="#FFFFFF"
            app:tint="#000000"
            app:elevation="4dp"
            app:fabSize="normal" />
    </LinearLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieGato"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="12dp"
        app:lottie_autoPlay="false"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/gato_dormido"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llControles" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E24"
        app:itemIconSize="28dp"
        app:itemIconTint="#FFFFFF"
        app:itemTextAppearanceActive="@style/EstiloTextoNavegador"
        app:itemTextAppearanceInactive="@style/EstiloTextoNavegador"
        app:itemTextColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/navegador_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>