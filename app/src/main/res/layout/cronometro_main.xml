<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/themeFondoPrincipal"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".CronometroActivity">

    <View
        android:id="@+id/circleTopLeft"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginStart="-55dp"
        android:layout_marginTop="80dp"
        android:alpha="0.13"
        android:background="@drawable/circulos_decorativos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/circleBottomRight"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circulos_decorativos"
        android:alpha="0.13"
        android:layout_marginEnd="-40dp"
        android:layout_marginBottom="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/themeFondoPrincipal"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:text="Enfoque"
                android:textColor="?attr/themeTextoPrimario"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:gravity="center_vertical"
                android:paddingEnd="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivEscudo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="20dp"
                    android:src="@drawable/ic_config_general"
                    app:tint="@color/color_verde_exito" />

                <ImageView
                    android:id="@+id/ivConfigTiempo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_configtiempo"
                    app:tint="?attr/themeTextoPrimario" />
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="SESIÓN DE ENFOQUE"
        android:textColor="?attr/themeTextoPrimario"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_semibold"
        android:letterSpacing="0.12"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/appBar" />

    <TextView
        android:id="@+id/tvSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enfocado en: Estudiar para el Examen"
        android:textColor="?attr/themeTextoSecundario"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_regular"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitulo" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/pbCronometro"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="24dp"
        android:max="100"
        android:progress="75"
        app:indicatorColor="?attr/themeTextoPrimario"
        app:indicatorSize="220dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitulo"
        app:trackColor="?attr/themeFondoTarjetaSecundaria"
        app:trackThickness="14dp"
        app:trackCornerRadius="7dp" />

    <TextView
        android:id="@+id/tvTiempo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25:00"
        android:textColor="?attr/themeTextoPrimario"
        android:textSize="48sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_bold"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toBottomOf="@+id/pbCronometro"
        app:layout_constraintEnd_toEndOf="@+id/pbCronometro"
        app:layout_constraintStart_toStartOf="@+id/pbCronometro"
        app:layout_constraintTop_toTopOf="@+id/pbCronometro" />

    <LinearLayout
        android:id="@+id/llIndicadores"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/pbCronometro">

        <TextView
            android:id="@+id/tvCiclo1"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/ciclo_activo"
            android:gravity="center"
            android:text="1"
            android:textColor="?attr/themeFondoPrincipal"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCiclo2"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/ciclo_inactivo"
            android:gravity="center"
            android:text="2"
            android:textColor="?attr/themeTextoTerciario"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCiclo3"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/ciclo_inactivo"
            android:gravity="center"
            android:text="3"
            android:textColor="?attr/themeTextoTerciario"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCiclo4"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ciclo_inactivo"
            android:gravity="center"
            android:text="4"
            android:textColor="?attr/themeTextoTerciario"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llControles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llIndicadores">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnRenunciar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Renunciar"
            app:backgroundTint="@color/color_rojo_peligro"
            app:tint="@color/white"
            app:elevation="4dp"
            app:fabSize="normal" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnPausar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="Pausar"
            app:backgroundTint="?attr/themeTextoPrimario"
            app:tint="?attr/themeFondoPrincipal"
            app:elevation="4dp"
            app:fabSize="normal" />
    </LinearLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieGato"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llControles"
        app:lottie_autoPlay="false"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/gato_dormido" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/themeFondoBarraNavegacion"
        app:itemIconSize="28dp"
        app:itemIconTint="?attr/themeTextoPrimario"
        app:itemTextColor="?attr/themeTextoPrimario"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/navegador_menu" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/themeFondoPrincipal"
        android:elevation="100dp"
        android:visibility="visible">

        <ImageView
            android:id="@+id/ivSplashIcono"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher_round"
            app:layout_constraintBottom_toTopOf="@id/tvSplashTitulo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"
            android:layout_marginBottom="28dp" />

        <TextView
            android:id="@+id/tvSplashTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Miau Focus"
            android:textColor="?attr/themeTextoPrimario"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toBottomOf="@id/ivSplashIcono"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>