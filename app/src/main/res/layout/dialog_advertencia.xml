<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_margin="36dp"
    android:background="@drawable/bg_tarjeta_advertencia"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingHorizontal="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/tvTituloAdvertencia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:text="Advertencia"
        android:textColor="?attr/themeTextoPrimario"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardGatoAdvertencia"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_marginTop="14dp"
        app:cardCornerRadius="65dp"
        app:cardBackgroundColor="?attr/themeFondoTarjetaSecundaria"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloAdvertencia">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieGatoAdvertencia"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/gato_llorando" />

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvMensajeAdvertencia"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:text="¿Estás seguro de renunciar a la sesión? Se aplicará el castigo correspondiente."
        android:textColor="?attr/themeTextoSecundario"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardGatoAdvertencia" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRenunciarAdvertencia"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/color_rojo_peligro"
        android:fontFamily="@font/poppins_semibold"
        android:text="Renunciar"
        android:textAllCaps="false"
        android:textColor="?attr/themeSobreAcento"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMensajeAdvertencia" />

    <TextView
        android:id="@+id/tvCancelarAdvertencia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:padding="4dp"
        android:fontFamily="@font/poppins_regular"
        android:text="Cancelar"
        android:textColor="?attr/themeTextoTerciario"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnRenunciarAdvertencia" />

</androidx.constraintlayout.widget.ConstraintLayout>
