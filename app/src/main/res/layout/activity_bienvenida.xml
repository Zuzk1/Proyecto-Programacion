
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/themeFondoPrincipal">

    <View
        android:id="@+id/circleTopRight"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/circulos_decorativos"
        android:alpha="0.20"
        android:layout_marginEnd="-60dp"
        android:layout_marginTop="-40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/circleBottomLeft"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circulos_decorativos"
        android:alpha="0.20"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="120dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tvTituloApp"
        android:layout_width="277dp"
        android:layout_height="75dp"
        android:layout_marginTop="48dp"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:text="Miau Focus"
        android:textColor="?attr/themeTextoPrimario"
        android:textSize="40sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBadge"
        android:layout_width="132dp"
        android:layout_height="28dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/chip_pomodoro"
        android:gravity="center"
        android:letterSpacing="0.15"
        android:paddingHorizontal="14dp"
        android:paddingVertical="4dp"
        android:fontFamily="@font/poppins_medium"
        android:text="POMODORO"
        android:textColor="?attr/themeAcentoClaro"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloApp" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/tvBadge"
        app:layout_constraintBottom_toTopOf="@+id/dotsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/btnComenzar" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnComenzar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="32dp"
        android:text="COMENZAR"
        android:textColor="?attr/themeSobreAcento"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_semibold"
        android:letterSpacing="0.12"
        app:backgroundTint="?attr/themeAcento"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>