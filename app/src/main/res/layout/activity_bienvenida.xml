<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F1F24"
    tools:context=".bienvenidaActivity">

    <!-- Círculo decorativo superior derecho -->
    <View
        android:id="@+id/circleTopRight"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/circulos_decorativos"
        android:alpha="0.20"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="-60dp"
        android:layout_marginTop="-40dp"/>

    <!-- Círculo decorativo inferior izquierdo -->
    <View
        android:id="@+id/circleBottomLeft"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circulos_decorativos"
        android:alpha="0.20"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="120dp"/>

    <!-- Nombre de la app -->
    <TextView
        android:id="@+id/tvTituloApp"
        android:layout_width="277dp"
        android:layout_height="75dp"
        android:layout_marginTop="48dp"
        android:fontFamily="serif"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:text="Miau Focus"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Chip / badge "POMODORO" -->
    <TextView
        android:id="@+id/tvBadge"
        android:layout_width="127dp"
        android:layout_height="24dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/chip_pomodoro"
        android:letterSpacing="0.15"
        android:paddingHorizontal="14dp"
        android:paddingVertical="4dp"
        android:text="POMODORO"
        android:gravity="center"
        android:textColor="#FF1744"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloApp" />

    <!-- Contenedor circular del Lottie -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLottie"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="28dp"
        app:cardCornerRadius="110dp"
        app:cardBackgroundColor="#26262C"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvBadge">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieGatoBienvenida"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/gato_asoma"/>

    </androidx.cardview.widget.CardView>

    <!-- Headline principal -->
    <TextView
        android:id="@+id/tvHeadline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:text="Concentra tu tiempo,\nalcanza tus metas"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:lineSpacingExtra="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardLottie"/>

    <!-- Descripción corta -->
    <TextView
        android:id="@+id/tvDescripcion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="36dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Trabaja en intervalos inteligentes con la técnica Pomodoro. Tu gato te guiará en cada sesión."
        android:textColor="#99FFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHeadline"/>

    <!-- Indicadores de página (dots) -->
    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvDescripcion">

        <View
            android:layout_width="20dp"
            android:layout_height="6dp"
            android:background="@drawable/punto_largo"
            android:layout_marginEnd="6dp"/>

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/puntos_inactivos_chiquitos"
            android:layout_marginEnd="6dp"/>

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/puntos_inactivos_chiquitos"/>

    </LinearLayout>

    <!-- Botón COMENZAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnComenzar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="32dp"
        android:text="COMENZAR"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        app:backgroundTint="#FF1744"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>