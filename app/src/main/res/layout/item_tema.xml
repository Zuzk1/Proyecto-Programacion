<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardTema"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="?attr/themeFondoTarjeta"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="2dp"
    app:strokeColor="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <LinearLayout
            android:id="@+id/llPreview"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:clipToOutline="true"
            android:background="@drawable/bg_preview_tema">

            <View
                android:id="@+id/viewFondoPreview"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <View
                android:id="@+id/viewAcentoPreview"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvNombreTema"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:textColor="?attr/themeTextoPrimario"
            android:textSize="13sp"
            tools:text="Azul Oscuro" />

        <TextView
            android:id="@+id/tvEstadoTema"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:textColor="?attr/themeTextoSecundario"
            android:textSize="11sp"
            tools:text="150 puntos" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
