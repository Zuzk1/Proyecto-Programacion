<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo_principal"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".analisisActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_fondo_principal"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/color_fondo_principal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:text="Estadisticas"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_semibold"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:gravity="center_vertical"
                android:paddingEnd="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivEscudo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="20dp"
                    android:src="@drawable/ic_escudo"
                    app:tint="@color/color_verde_exito" />

                <ImageView
                    android:id="@+id/ivConfigTiempo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_configtiempo"
                    app:tint="@color/white" />
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:id="@+id/cardEstadisticas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/carta_oscura"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBar">

        <TextView
            android:id="@+id/tvTiempoTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/color_gris_texto_secundario"
            android:textSize="15sp"
            tools:text="Tiempo de Enfoque Total: 18 hrs" />

        <TextView
            android:id="@+id/tvPomodorosCompletados"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/color_gris_texto_secundario"
            android:textSize="15sp"
            tools:text="Pomodoros Completados: 36" />

        <TextView
            android:id="@+id/tvRachaActual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/color_gris_texto_secundario"
            android:textSize="15sp"
            tools:text="Racha Actual: 7 Días" />

        <TextView
            android:id="@+id/tvTasaFallos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/color_gris_texto_secundario"
            android:textSize="15sp"
            tools:text="Tasa de Fallos: 12% · 3 bloques abandonados" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/llPuntos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/carta_oscura"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardEstadisticas">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐱"
            android:textSize="28sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/tvPuntos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/white"
            android:textSize="18sp"
            tools:text="350 Puntos" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTienda"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:text="Tienda de Temas"
            android:textColor="@color/black"
            android:textSize="13sp"
            app:backgroundTint="@color/white"
            app:cornerRadius="24dp"
            app:rippleColor="@color/color_gris_ripple" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTituloGrafica"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:fontFamily="@font/poppins_semibold"
        android:text="Pomodoros Completados por Día"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llPuntos" />

    <LinearLayout
        android:id="@+id/llGraficaContenedor"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/carta_oscura"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloGrafica">

        <LinearLayout
            android:id="@+id/llContenedorBarras"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:baselineAligned="false"
            android:orientation="horizontal" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTituloActividades"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:fontFamily="@font/poppins_semibold"
        android:text="Actividades Recientes"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llGraficaContenedor" />

    <LinearLayout
        android:id="@+id/llActividadesRecientes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/carta_oscura"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloActividades"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView">

        <TextView
            android:id="@+id/tvActividadesRecientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/color_gris_texto_secundario"
            android:textSize="13sp"
            android:text="Aún no hay actividades completadas" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_fondo_barra_navegacion"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/navegador_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>