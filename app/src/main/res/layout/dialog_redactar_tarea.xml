<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_margin="36dp"
    android:background="@drawable/bg_tarjeta_permiso"
    android:paddingHorizontal="24dp"
    android:paddingVertical="22dp">

    <TextView
        android:id="@+id/tvTituloRedactarTarea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/etRedactarTareaInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Ej. Hacer tarea de historia"
        android:inputType="textCapSentences"
        android:fontFamily="@font/poppins_regular"
        android:textColor="@color/white"
        android:textColorHint="@color/color_gris_texto_terciario"
        android:backgroundTint="@color/color_azul_principal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTituloRedactarTarea" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuardarRedactarTarea"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/color_azul_principal"
        android:fontFamily="@font/poppins_semibold"
        android:text="Guardar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etRedactarTareaInput" />

    <TextView
        android:id="@+id/tvCancelarRedactarTarea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:padding="4dp"
        android:fontFamily="@font/poppins_regular"
        android:text="Cancelar"
        android:textColor="@color/color_gris_texto_terciario"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnGuardarRedactarTarea" />

</androidx.constraintlayout.widget.ConstraintLayout>
